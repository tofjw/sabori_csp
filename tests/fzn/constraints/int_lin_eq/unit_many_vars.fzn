% int_lin_eq unit coefficients: 5 variables with mixed signs
% a + b - c - d + e = 3
% a=2,b=3 fixed => 5 - c - d + e = 3 => e - c - d = -2 => e = c + d - 2
% c=1,d=1 => e=0 (out), c=1,d=2 => e=1, c=2,d=1 => e=1
var 2..2: a :: output_var;
var 3..3: b :: output_var;
var 1..3: c :: output_var;
var 1..3: d :: output_var;
var 1..3: e :: output_var;

constraint int_lin_eq([1, 1, -1, -1, 1], [a, b, c, d, e], 3);

solve satisfy;
