% Boundary: all-negative array, max is the least-negative element.
var -10..0: m :: output_var;
var -10..0: x1 :: output_var;
var -10..0: x2 :: output_var;
var -10..0: x3 :: output_var;
constraint int_eq(x1, -3);
constraint int_eq(x2, -7);
constraint int_eq(x3, -5);
constraint array_int_maximum(m, [x1, x2, x3]);
solve satisfy;
