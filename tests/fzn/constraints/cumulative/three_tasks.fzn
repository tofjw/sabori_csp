% 3 tasks with different requirements, capacity=3
% Task 1: dur=2, req=2; Task 2: dur=2, req=1; Task 3: dur=2, req=2
% Total energy = 2*2 + 2*1 + 2*2 = 10, needs at least ceil(10/3) = 4 time units
var 0..4: s1 :: output_var;
var 0..4: s2 :: output_var;
var 0..4: s3 :: output_var;
var 2..2: d1;
var 2..2: d2;
var 2..2: d3;
var 2..2: r1;
var 1..1: r2;
var 2..2: r3;
var 3..3: cap;
constraint fzn_cumulative([s1, s2, s3], [d1, d2, d3], [r1, r2, r3], cap);
solve satisfy;
