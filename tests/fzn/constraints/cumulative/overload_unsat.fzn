% 2 tasks that must overlap, total req > capacity → UNSAT
% Task 1: start in [0,0], dur=3, req=2
% Task 2: start in [0,0], dur=3, req=2
% Capacity = 3
var 0..0: s1 :: output_var;
var 0..0: s2 :: output_var;
var 3..3: d1;
var 3..3: d2;
var 2..2: r1;
var 2..2: r2;
var 3..3: cap;
constraint fzn_cumulative([s1, s2], [d1, d2], [r1, r2], cap);
solve satisfy;
