% Simple regular constraint test
% DFA: accepts strings over {1,2} that end with 1
% States: 1 (start), 2 (saw 1 = accepting)
% Transitions:
%   state 1, symbol 1 -> state 2
%   state 1, symbol 2 -> state 1
%   state 2, symbol 1 -> state 2
%   state 2, symbol 2 -> state 1
var 1..2: x1 :: output_var;
var 1..2: x2 :: output_var;
var 1..2: x3 :: output_var;
array [1..4] of int: d = [2, 1, 2, 1];
constraint fzn_regular([x1, x2, x3], 2, 2, d, 1, {2});
solve satisfy;
