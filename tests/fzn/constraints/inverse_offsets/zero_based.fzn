% fzn_inverse_offsets (0-based offsets): f=[1,2,0] has inverse invf=[2,0,1].
var 0..2: f1 :: output_var;
var 0..2: f2 :: output_var;
var 0..2: f3 :: output_var;
var 0..2: g1 :: output_var;
var 0..2: g2 :: output_var;
var 0..2: g3 :: output_var;
constraint int_eq(f1, 1);
constraint int_eq(f2, 2);
constraint int_eq(f3, 0);
constraint fzn_inverse_offsets([f1, f2, f3], 0, [g1, g2, g3], 0);
solve satisfy;
