% fzn_inverse_offsets (1-based): f=[2,3,1] has inverse invf=[3,1,2].
var 1..3: f1 :: output_var;
var 1..3: f2 :: output_var;
var 1..3: f3 :: output_var;
var 1..3: g1 :: output_var;
var 1..3: g2 :: output_var;
var 1..3: g3 :: output_var;
constraint int_eq(f1, 2);
constraint int_eq(f2, 3);
constraint int_eq(f3, 1);
constraint fzn_inverse_offsets([f1, f2, f3], 1, [g1, g2, g3], 1);
solve satisfy;
