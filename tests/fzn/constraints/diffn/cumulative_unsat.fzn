var 0..1: x1 :: output_var;
var 0..1: x2 :: output_var;
var 0..1: x3 :: output_var;
var 0..1: y1 :: output_var;
var 0..1: y2 :: output_var;
var 0..1: y3 :: output_var;
var 2..2: dx1;
var 2..2: dx2;
var 2..2: dx3;
var 1..1: dy1;
var 1..1: dy2;
var 1..1: dy3;
constraint fzn_diffn([x1, x2, x3], [y1, y2, y3], [dx1, dx2, dx3], [dy1, dy2, dy3]);
solve satisfy;
