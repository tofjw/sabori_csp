% int_lin_eq substitution: verify all solutions
% z = 5 - y (def), constraint: z != x => (5-y) != x => x+y != 5
% x,y in 1..3: solutions are all pairs except (2,3) and (3,2) — 7 solutions
var 1..3: x :: output_var;
var 1..3: y :: output_var;
var 1..5: z :: is_defined_var;
constraint int_lin_eq([1, 1], [z, y], 5);
constraint int_lin_ne([1, -1], [z, x], 0);
solve satisfy;
