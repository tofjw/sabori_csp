% int_lin_le_imp: negative coefficients
% b=1 -> 3*x - 2*y <= 5, x in 1..5, y in 1..5
% Equivalent to: 3*x - 5 <= 2*y, i.e. y >= ceil((3*x-5)/2)
% x=1: y>=1 (all), x=2: y>=1 (all), x=3: y>=2, x=4: y>=4, x=5: y>=5
% Total: 5+5+4+2+1 = 17 solutions
var 1..5: x :: output_var;
var 1..5: y :: output_var;
var bool: b = true;
constraint int_lin_le_imp([3, -2], [x, y], 5, b);
solve satisfy;
