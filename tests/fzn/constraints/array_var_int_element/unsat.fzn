% UNSAT: idx=2 selects a2=7, but result is pinned to 5.
var 1..3: idx :: output_var;
var 1..10: a1 :: output_var;
var 1..10: a2 :: output_var;
var 1..10: a3 :: output_var;
var 1..10: result :: output_var;
constraint int_eq(idx, 2);
constraint int_eq(a1, 5);
constraint int_eq(a2, 7);
constraint int_eq(a3, 9);
constraint int_eq(result, 5);
constraint array_var_int_element(idx, [a1, a2, a3], result);
solve satisfy;
