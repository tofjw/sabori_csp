% Boundary case: zero-duration task at the end-point (exclusive) of another
% task is allowed: s2+d2 <= s1.
% s1 = 6 (d=0), s2 = 4 (d=2) -> task 2 covers [4, 6); point 6 is at the boundary
% Expected: SAT (single solution)
var 6..6: s1 :: output_var;
var 4..4: s2 :: output_var;
var 0..0: d1;
var 2..2: d2;
constraint fzn_disjunctive_strict([s1, s2], [d1, d2]);
solve satisfy;
