% Boundary case: zero-duration task at the start of another task is allowed
% under disjunctive_strict (the inequality s1+d1 <= s2 holds with equality).
% s1 = 4 (d=0), s2 = 4 (d=2)
% Expected: SAT (single solution)
var 4..4: s1 :: output_var;
var 4..4: s2 :: output_var;
var 0..0: d1;
var 2..2: d2;
constraint fzn_disjunctive_strict([s1, s2], [d1, d2]);
solve satisfy;
