% Regression: zero-duration task strictly inside another task's interval
% must be rejected under disjunctive_strict semantics.
% s1 = 5 (d=0), s2 = 4 (d=2) -> task 1 point 5 is inside task 2's [4, 6)
% Expected: UNSATISFIABLE
var 5..5: s1 :: output_var;
var 4..4: s2 :: output_var;
var 0..0: d1;
var 2..2: d2;
constraint fzn_disjunctive_strict([s1, s2], [d1, d2]);
solve satisfy;
