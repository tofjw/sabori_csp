% UNSAT: bool_lt_reif(a,b,r) sets r <-> (a < b). With a=1,b=1, a<b is false,
% so r must be 0, but r is pinned to 1.
var bool: a :: output_var;
var bool: b :: output_var;
var bool: r :: output_var;
constraint bool_lt_reif(a, b, r);
constraint int_eq(a, 1);
constraint int_eq(b, 1);
constraint bool_eq(r, 1);
solve satisfy;
