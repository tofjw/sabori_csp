% UNSAT: array_bool_xor requires an odd number of true entries.
% a=1,b=1 forces c=1 (to stay odd), but c is pinned to 0 (2 trues = even).
var bool: a :: output_var;
var bool: b :: output_var;
var bool: c :: output_var;

constraint array_bool_xor([a, b, c]);
constraint int_eq(a, 1);
constraint int_eq(b, 1);
constraint int_eq(c, 0);

solve satisfy;
