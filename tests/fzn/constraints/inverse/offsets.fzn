% inverse with asymmetric offsets:
%   f indexed [1..3] (foff=2 means values are in [2..4])
%   invf indexed [1..3] (invfoff=1 means values are in [1..3])
%   So f's values represent indices into invf's *original* index set [2..4],
%   and invf's values represent indices into f's *original* index set [1..3].
% Constraint: f[i]=j ⟺ invf[j-1] = i (after offset translation)
% With f1=2 fixed, the only valid solution is the identity-shift.
var 2..4: f1 :: output_var;
var 2..4: f2 :: output_var;
var 2..4: f3 :: output_var;
var 1..3: g1 :: output_var;
var 1..3: g2 :: output_var;
var 1..3: g3 :: output_var;
constraint int_eq(f1, 2);
constraint int_eq(f2, 3);
constraint fzn_inverse_offsets([f1, f2, f3], 2, [g1, g2, g3], 1);
solve satisfy;
